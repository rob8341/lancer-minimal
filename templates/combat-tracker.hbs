<section id="combat" class="{{cssClass}}" aria-label="{{localize 'COMBAT.SidebarTitle'}}">
    <header id="combat-round" class="combat-tracker-header flexrow">
        <h3 class="encounter-title noborder">
            {{#if user.isGM}}
            <a class="combat-button combat-control" aria-label="{{localize 'COMBAT.EncounterCreate'}}"
               data-tooltip="COMBAT.EncounterCreate" data-control="createEncounter">
                <i class="fas fa-plus"></i>
            </a>
            {{/if}}
            {{#if combatCount}}
            <span class="encounter-count">{{localize "COMBAT.Encounter"}} {{currentIndex}} / {{combatCount}}</span>
            {{/if}}
        </h3>
        <nav class="encounters flexrow {{#unless combatCount}}hidden{{/unless}}">
            {{#if user.isGM}}
            <a class="combat-button combat-control {{#unless previousId}}inactive{{/unless}}"
               aria-label="{{localize 'COMBAT.EncounterPrevious'}}" data-tooltip="COMBAT.EncounterPrevious"
               data-control="previousEncounter"><i class="fas fa-caret-left"></i></a>
            <a class="combat-button combat-control {{#unless nextId}}inactive{{/unless}}"
               aria-label="{{localize 'COMBAT.EncounterNext'}}" data-tooltip="COMBAT.EncounterNext"
               data-control="nextEncounter"><i class="fas fa-caret-right"></i></a>
            {{/if}}
            <a class="combat-button combat-control" aria-label="{{localize 'COMBAT.RoundPrev'}}"
               data-tooltip="COMBAT.RoundPrev" data-control="previousRound"><i class="fas fa-step-backward"></i></a>
            <h4 class="round">{{localize "COMBAT.Round"}} {{round}}</h4>
            <a class="combat-button combat-control" aria-label="{{localize 'COMBAT.RoundNext'}}"
               data-tooltip="COMBAT.RoundNext" data-control="nextRound"><i class="fas fa-step-forward"></i></a>
        </nav>
    </header>

    {{! Turn Type Indicator }}
    {{#if started}}
    <div class="lancer-turn-indicator" style="padding: 8px 12px; background: {{#if isPlayerTurn}}#2980b9{{else}}#cc2936{{/if}}; color: white; font-weight: bold; text-align: center; margin: 4px 8px; border-radius: 4px;">
        {{#if isPlayerTurn}}
        <i class="fas fa-user"></i> PLAYER TURN
        {{else}}
        <i class="fas fa-skull"></i> ENEMY TURN
        {{/if}}
        {{#if user.isGM}}
        <button type="button" class="lancer-reset-all" style="float: right; font-size: 10px; padding: 2px 8px; background: rgba(0,0,0,0.3); border: none; color: white; cursor: pointer; border-radius: 3px;">
            <i class="fas fa-redo"></i> Reset
        </button>
        {{/if}}
    </div>
    {{/if}}

    <ol id="combat-tracker" class="directory-list">
        {{#each turns}}
        <li class="combatant actor directory-item flexrow {{this.css}}"
            data-combatant-id="{{this.id}}" 
            style="border-left: 4px solid {{#if this.isNPC}}#cc2936{{else}}#2980b9{{/if}}; {{#if this.hasActed}}opacity: 0.5;{{/if}}">
            <img class="token-image" data-src="{{this.img}}" title="{{this.name}}" alt="{{this.name}}" src="{{this.img}}"/>
            <div class="token-name flexcol">
                <h4>{{this.name}}</h4>
                <div class="combatant-controls flexrow">
                    {{#if ../user.isGM}}
                    <a class="combatant-control {{#if this.hidden}}active{{/if}}"
                       aria-label="{{localize 'COMBAT.ToggleVis'}}" data-tooltip="COMBAT.ToggleVis"
                       data-control="toggleHidden"><i class="fas fa-eye-slash"></i></a>
                    <a class="combatant-control {{#if this.defeated}}active{{/if}}"
                       aria-label="{{localize 'COMBAT.ToggleDead'}}" data-tooltip="COMBAT.ToggleDead"
                       data-control="toggleDefeated"><i class="fas fa-skull"></i></a>
                    {{/if}}
                    {{#if this.canPing}}
                    <a class="combatant-control" aria-label="{{localize 'COMBAT.PingCombatant'}}"
                       data-tooltip="COMBAT.PingCombatant" data-control="pingCombatant"><i class="fa-solid fa-bullseye-arrow"></i></a>
                    {{/if}}
                </div>
            </div>

            <div class="token-initiative">
                {{#if this.hasActed}}
                    <span style="color: #27ae60; font-weight: bold; font-size: 14px;"><i class="fas fa-check"></i></span>
                    {{#if ../user.isGM}}
                    <a class="lancer-unclaim" title="Unclaim" style="margin-left: 4px; color: #cc2936; cursor: pointer;"><i class="fas fa-undo"></i></a>
                    {{/if}}
                {{else if this.canClaim}}
                    <a class="lancer-claim" title="Claim Slot" style="background: #27ae60; color: white; padding: 3px 8px; border-radius: 3px; font-weight: bold; cursor: pointer; font-size: 11px; text-decoration: none;">
                        <i class="fas fa-hand-point-right"></i> Claim
                    </a>
                {{else}}
                    <span style="color: #888; font-style: italic; font-size: 11px;">Wait</span>
                {{/if}}
            </div>

            {{#if ../user.isGM}}
            <div class="token-effects">
                {{#each this.effects}}
                <img class="token-effect" src="{{this}}" alt="Effect"/>
                {{/each}}
            </div>
            {{/if}}
        </li>
        {{/each}}
    </ol>

    <nav id="combat-controls" class="directory-footer flexrow" data-tooltip-direction="UP">
        {{#if hasCombat}}
            {{#if user.isGM}}
                {{#if round}}
                <a class="combat-button combat-control" aria-label="{{localize 'COMBAT.EndCombat'}}"
                   data-tooltip="COMBAT.EndCombat" data-control="endCombat"><i class="fas fa-flag-checkered"></i></a>
                {{else}}
                <a class="combat-button combat-control center" aria-label="{{localize 'COMBAT.Begin'}}"
                   data-tooltip="COMBAT.Begin" data-control="startCombat">{{localize "COMBAT.Begin"}}</a>
                {{/if}}
            {{else if round}}
            <a class="combat-button combat-control center" aria-label="{{localize 'COMBAT.TurnEnd'}}"
               data-tooltip="COMBAT.TurnEnd" data-control="nextTurn">{{localize "COMBAT.TurnEnd"}}</a>
            {{/if}}
        {{else if user.isGM}}
        <a class="combat-button combat-control center" aria-label="{{localize 'COMBAT.EncounterCreate'}}"
           data-tooltip="COMBAT.EncounterCreate" data-control="createEncounter">{{localize "COMBAT.EncounterCreate"}}</a>
        {{/if}}
    </nav>
</section>
