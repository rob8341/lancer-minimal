{{!-- Lancer Minimal — NPC Sheet --}}
<form class="lancer-minimal sheet actor npc-sheet" autocomplete="off">

  {{!-- ===================== HEADER ===================== --}}
  <header class="sheet-header">
    <div class="npc-portrait">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
      {{#if effects.length}}
      <div class="status-effects-overlay">
        {{#each effects}}
        <img class="status-icon" src="{{this.icon}}" title="{{this.label}}" />
        {{/each}}
      </div>
      {{/if}}
    </div>

    <div class="header-fields">
      <div class="field-row">
        <div class="field-group">
          <label>Name</label>
          <input name="name" type="text" value="{{actor.name}}" placeholder="NPC Name" />
        </div>
        <div class="field-group compact">
          <label>Tier</label>
          <input name="system.tier" type="number" value="{{system.tier}}" min="1" max="3" class="stat-input" style="width:50px;" />
        </div>
      </div>
      <div class="field-row" style="margin-top: 6px; align-items: center; gap: 8px;">
        <div class="recharge-group" style="display: flex; align-items: center; gap: 6px; padding: 4px 8px; border: 1px solid var(--lnc-accent, #cc2936); border-radius: 4px; background: var(--lnc-bg-mid, #f0f4f8);">
          <a class="recharge-roll-btn" title="Roll Recharge (1d6 ≥ target)"><i class="fas fa-sync-alt"></i></a>
          <label style="font-size: 0.85em; font-weight: bold;">Recharge</label>
          <input name="system.recharge_target" type="number" value="{{system.recharge_target}}" min="1" max="6" style="width: 32px; text-align: center;" title="Target number (roll this or higher)" />
          <span style="font-size: 0.85em;">+</span>
          <input name="system.recharge_ready" type="checkbox" {{#if system.recharge_ready}}checked{{/if}} style="width: 16px; height: 16px;" title="Recharge ready" />
          <label style="font-size: 0.85em;">Ready</label>
        </div>
        <a class="btn-scan scan-to-chat" draggable="true" data-macro-type="scanToChat" title="Send NPC stats to chat"><i class="fas fa-satellite-dish"></i> Scan to Chat</a>
      </div>
    </div>
  </header>

  {{!-- ===================== STATS BAR 1 ===================== --}}
  <div class="stats-bar">
    <div class="stat-cell">
      <span class="stat-label">HP</span>
      <div class="stat-pair">
        <input name="system.hp.value" type="number" value="{{system.hp.value}}" min="0" class="stat-input" title="Current HP" />
        <span class="stat-sep">/</span>
        <input name="system.hp.max" type="number" value="{{system.hp.max}}" min="0" class="stat-input" title="Max HP" />
      </div>
    </div>
    <div class="stat-cell">
      <span class="stat-label">Evasion</span>
      <input name="system.evasion" type="number" value="{{system.evasion}}" min="0" class="stat-input" />
    </div>
    <div class="stat-cell">
      <span class="stat-label">Speed</span>
      <input name="system.speed" type="number" value="{{system.speed}}" min="0" class="stat-input" />
    </div>
    <div class="stat-cell">
      <span class="stat-label">Heat</span>
      <div class="stat-pair">
        <input name="system.heat.value" type="number" value="{{system.heat.value}}" min="0" class="stat-input" title="Current Heat" />
        <span class="stat-sep">/</span>
        <input name="system.heat.max" type="number" value="{{system.heat.max}}" min="0" class="stat-input" title="Heat Cap" />
      </div>
    </div>
    <div class="stat-cell">
      <span class="stat-label">Sensors</span>
      <input name="system.sensors" type="number" value="{{system.sensors}}" min="0" class="stat-input" />
    </div>
  </div>

  {{!-- ===================== STATS BAR 2 ===================== --}}
  <div class="stats-bar">
    <div class="stat-cell">
      <span class="stat-label">Structure</span>
      <div class="stat-pair">
        <a class="structure-roll-btn" draggable="true" data-macro-type="structureRoll" title="Structure Damage Roll"><i class="fas fa-heart-broken"></i></a>
        <input name="system.structure.value" type="number" value="{{system.structure.value}}" min="0" class="stat-input" title="Current Structure" />
        <span class="stat-sep">/</span>
        <input name="system.structure.max" type="number" value="{{system.structure.max}}" min="0" class="stat-input" title="Max Structure" />
      </div>
    </div>
    <div class="stat-cell">
      <span class="stat-label">Stress</span>
      <div class="stat-pair">
        <a class="stress-roll-btn" draggable="true" data-macro-type="stressRoll" title="Overheat Roll"><i class="fas fa-fire"></i></a>
        <input name="system.stress.value" type="number" value="{{system.stress.value}}" min="0" class="stat-input" title="Current Stress" />
        <span class="stat-sep">/</span>
        <input name="system.stress.max" type="number" value="{{system.stress.max}}" min="0" class="stat-input" title="Max Stress" />
      </div>
    </div>
    <div class="stat-cell">
      <span class="stat-label">Armor</span>
      <input name="system.armor" type="number" value="{{system.armor}}" min="0" class="stat-input" />
    </div>
    <div class="stat-cell">
      <span class="stat-label">E-Def</span>
      <input name="system.edef" type="number" value="{{system.edef}}" min="0" class="stat-input" />
    </div>
    <div class="stat-cell">
      <span class="stat-label">Size</span>
      <input name="system.size" type="number" value="{{system.size}}" min="0.5" step="0.5" class="stat-input" />
    </div>
    <div class="stat-cell">
      <span class="stat-label">Save</span>
      <input name="system.save" type="number" value="{{system.save}}" min="0" class="stat-input" />
    </div>
  </div>

  {{!-- ===================== HASE SKILLS ===================== --}}
  <div class="section-header" style="margin: 0; padding: 8px 10px 4px; border-bottom: 2px solid var(--lnc-accent);">
    <h2 style="margin: 0; border: none;"><i class="fas fa-cogs"></i> Mech Skills</h2>
  </div>
  <div class="hase-bar">
    <div class="hase-cell">
      <span class="hase-label">Hull</span>
      <div style="display: flex; align-items: center; gap: 4px;">
        <a class="hase-roll-btn" draggable="true" data-macro-type="haseCheck" data-skill="hull" title="Roll Hull Check"><i class="fas fa-dice-d20"></i></a>
        <input name="system.hull" type="number" value="{{system.hull}}" min="-6" max="6" class="hase-input" />
      </div>
    </div>
    <div class="hase-cell">
      <span class="hase-label">Agility</span>
      <div style="display: flex; align-items: center; gap: 4px;">
        <a class="hase-roll-btn" draggable="true" data-macro-type="haseCheck" data-skill="agility" title="Roll Agility Check"><i class="fas fa-dice-d20"></i></a>
        <input name="system.agility" type="number" value="{{system.agility}}" min="-6" max="6" class="hase-input" />
      </div>
    </div>
    <div class="hase-cell">
      <span class="hase-label">Systems</span>
      <div style="display: flex; align-items: center; gap: 4px;">
        <a class="hase-roll-btn" draggable="true" data-macro-type="haseCheck" data-skill="systems" title="Roll Systems Check"><i class="fas fa-dice-d20"></i></a>
        <input name="system.systems" type="number" value="{{system.systems}}" min="-6" max="6" class="hase-input" />
      </div>
    </div>
    <div class="hase-cell">
      <span class="hase-label">Engineering</span>
      <div style="display: flex; align-items: center; gap: 4px;">
        <a class="hase-roll-btn" draggable="true" data-macro-type="haseCheck" data-skill="engineering" title="Roll Engineering Check"><i class="fas fa-dice-d20"></i></a>
        <input name="system.engineering" type="number" value="{{system.engineering}}" min="-6" max="6" class="hase-input" />
      </div>
    </div>
  </div>

  {{!-- ===================== TABS ===================== --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="combat"><i class="fas fa-crosshairs"></i> Combat</a>
    <a class="item" data-tab="info"><i class="fas fa-info-circle"></i> Info</a>
  </nav>

  {{!-- ===================== BODY ===================== --}}
  <section class="sheet-body">

    {{!-- ============ COMBAT TAB ============ --}}
    <div class="tab" data-group="primary" data-tab="combat">

      {{!-- Weapons --}}
      <div class="section-header">
        <h2><i class="fas fa-crosshairs"></i> Weapons</h2>
        <a class="item-create btn-add" data-type="weapon"><i class="fas fa-plus"></i> Add</a>
      </div>
      <div class="item-list weapons-list">
        {{#each weapons}}
        <div class="item list-entry item-row" data-item-id="{{this._id}}">
          <img class="item-img item-attack" src="{{this.img}}" title="Attack" />
          <span class="item-name">{{this.name}}</span>
          <div class="item-tags">
            {{#if this.system.mount}}<span class="item-tag">{{this.system.mount}}</span>{{/if}}
            {{#if this.system.type}}<span class="item-tag">{{this.system.type}}</span>{{/if}}
            {{#if this.system.damage}}<span class="item-tag accent">{{this.system.damage}}</span>{{/if}}
            {{#if this.system.range}}<span class="item-tag">{{this.system.range}}</span>{{/if}}
            {{#if this.system.tags}}<span class="item-tag">{{this.system.tags}}</span>{{/if}}
          </div>
          <div class="item-controls">
            <a class="item-attack" draggable="true" data-macro-type="weaponAttack" data-item-id="{{this._id}}" title="Attack"><i class="fas fa-crosshairs"></i></a>
            <a class="item-chat" title="Send to Chat"><i class="fas fa-comment"></i></a>
            <a class="item-lock" title="{{#if this.system.locked}}Unlock{{else}}Lock{{/if}}">
              <i class="fas {{#if this.system.locked}}fa-lock{{else}}fa-lock-open{{/if}}"></i>
            </a>
            <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{else}}
        <p class="empty-notice">No weapons — click <strong>+ Add</strong> or drag weapons here.</p>
        {{/each}}
      </div>

      {{!-- Base Systems --}}
      <div class="section-header">
        <h2><i class="fas fa-microchip"></i> Base Systems</h2>
        <a class="item-create btn-add" data-type="system" data-category="base"><i class="fas fa-plus"></i> Add</a>
      </div>
      <div class="item-list base-systems-list">
        {{#each baseSystems}}
        <div class="item list-entry item-row" data-item-id="{{this._id}}">
          <img class="item-img" src="{{this.img}}" />
          <span class="item-name">{{this.name}}</span>
          <div class="item-tags">
            {{#if this.system.sp}}<span class="item-tag accent">SP {{this.system.sp}}</span>{{/if}}
            {{#if this.system.tags}}<span class="item-tag">{{this.system.tags}}</span>{{/if}}
          </div>
          <div class="item-controls">
            <a class="item-chat" title="Send to Chat"><i class="fas fa-comment"></i></a>
            <a class="item-lock" title="{{#if this.system.locked}}Unlock{{else}}Lock{{/if}}">
              <i class="fas {{#if this.system.locked}}fa-lock{{else}}fa-lock-open{{/if}}"></i>
            </a>
            <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{else}}
        <p class="empty-notice">No base systems — click <strong>+ Add</strong> or drag systems here.</p>
        {{/each}}
      </div>

      {{!-- Optional Systems --}}
      <div class="section-header">
        <h2><i class="fas fa-cog"></i> Optional Systems</h2>
        <a class="item-create btn-add" data-type="system" data-category="optional"><i class="fas fa-plus"></i> Add</a>
      </div>
      <div class="item-list optional-systems-list">
        {{#each optionalSystems}}
        <div class="item list-entry item-row" data-item-id="{{this._id}}">
          <img class="item-img" src="{{this.img}}" />
          <span class="item-name">{{this.name}}</span>
          <div class="item-tags">
            {{#if this.system.sp}}<span class="item-tag accent">SP {{this.system.sp}}</span>{{/if}}
            {{#if this.system.tags}}<span class="item-tag">{{this.system.tags}}</span>{{/if}}
          </div>
          <div class="item-controls">
            <a class="item-chat" title="Send to Chat"><i class="fas fa-comment"></i></a>
            <a class="item-lock" title="{{#if this.system.locked}}Unlock{{else}}Lock{{/if}}">
              <i class="fas {{#if this.system.locked}}fa-lock{{else}}fa-lock-open{{/if}}"></i>
            </a>
            <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{else}}
        <p class="empty-notice">No optional systems — click <strong>+ Add</strong> or drag systems here.</p>
        {{/each}}
      </div>

    </div>{{!-- /combat --}}

    {{!-- ============ INFO TAB ============ --}}
    <div class="tab" data-group="primary" data-tab="info">

      <div class="section-header">
        <h2><i class="fas fa-chess"></i> Tactics</h2>
      </div>
      <div class="field-group">
        <textarea name="system.tactics" rows="12" style="width:100%; resize:vertical;" placeholder="NPC tactics, behavior patterns, combat strategy...">{{system.tactics}}</textarea>
      </div>

    </div>{{!-- /info --}}

  </section>
</form>
